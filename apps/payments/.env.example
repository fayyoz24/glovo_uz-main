# ================================================================
# PAYMENTS — Environment Variables
# ================================================================
# Barcha qiymatlarni .env fayliga ko'chiring (hech qachon git ga push qilmang)

# ------------------------------------------------------------------
# Click (click.uz) — Merchant Cabinet → Settings
# ------------------------------------------------------------------
CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_SERVICE_ID=your_click_service_id
CLICK_SECRET_KEY=your_click_secret_key
CLICK_MERCHANT_USER_ID=your_click_merchant_user_id

# Customer redirect after Click payment
CLICK_RETURN_URL=https://yourapp.uz/payment/callback/click/

# ------------------------------------------------------------------
# Payme (payme.uz) — Merchant Cabinet → Settings
# ------------------------------------------------------------------
PAYME_MERCHANT_ID=your_payme_merchant_id

# Cashier key from Payme cabinet (for production callbacks)
PAYME_SECRET_KEY=your_payme_cashier_secret_key

# Test key (for Payme sandbox/test environment)
PAYME_TEST_KEY=your_payme_test_cashier_key

# Set to True in development/staging to use Payme sandbox
PAYME_TEST_MODE=False

# Customer redirect after Payme payment
PAYME_RETURN_URL=https://yourapp.uz/payment/callback/payme/

