# =========================================================
# Glovo UZ Backend — environment variables example
# Copy to .env (local/dev) or .env.staging / .env.prod and fill in real values.
# Never commit the real .env files — see Section 27 CI/CD: "Maintain separate
# env files for local/dev/staging/prod".
# =========================================================
DEBUG=True
# --- Django core ---
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# --- Postgres ---
POSTGRES_DB=glovo_uz_dev
POSTGRES_USER=glovo_user
POSTGRES_PASSWORD=devpassword
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis (Celery broker/result backend, Channels layer, cache) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=devpassword
REDIS_URL=redis://:devpassword@redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_CONCURRENCY=4
CELERY_TASK_ALWAYS_EAGER=True
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP = True
CELERY_BROKER_CONNECTION_MAX_RETRIES = 3


# --- JWT / Auth (Section 23) ---
JWT_ACCESS_TOKEN_LIFETIME_MIN=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30
OTP_RATE_LIMIT_PER_HOUR=5

# --- Object storage (S3-compatible / Cloudinary, Section 8) ---
STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=glovo-uz-media
AWS_S3_REGION_NAME=eu-central-1
AWS_S3_ENDPOINT_URL=

# --- Maps (Section 6) ---
GEOCODING_PROVIDER=yandex
YANDEX_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=
TWOGIS_API_KEY=

# --- Payments: Click (Section 19.6) ---
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_MERCHANT_USER_ID=
CLICK_SECRET_KEY=

# --- Payments: Payme (Section 19.7) ---
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# --- Notifications (Section 20) ---
SMS_PROVIDER=eskiz
SMS_API_KEY=
PUSH_PROVIDER=fcm
FCM_SERVER_KEY=
TELEGRAM_ADMIN_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Monitoring (Section 8, phase 2) ---
SENTRY_DSN=

# --- Nginx ---
NGINX_SERVER_NAME=localhost
HTTP_PORT=80
HTTPS_PORT=443

# --- Gunicorn (prod) ---
GUNICORN_WORKERS=4
GUNICORN_THREADS=2

# --email--
ESKIZ_EMAIL=
ESKIZ_PASSWORD=

# --telegram--
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_BOT_USERNAME=bozorchiboy_bot
TELEGRAM_BOT_TOKEN=8755941082:AAGCC-sM4TMq9bsDJdS8Dl7KxORiLLyTUKA
TELEGRAM_WEBHOOK_SECRET=random-string
BACKEND_BASE_URL=http://localhost:8000
TELEGRAM_BOT_SHARED_SECRET=random-string
BACKEND_BASE_URL=http://localhost:8000


CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
curl -v -X POST http://localhost:8000/api/v1/auth/telegram/bind-phone/ ^
  -H "Content-Type: application/json" ^
  -H "X-Telegram-Bot-Api-Secret-Token: random-string" ^
  -d "{\"phone\":\"+998770028965\",\"telegram_user_id\":1230868707,\"telegram_username\":\"abbosbek12323\"}"