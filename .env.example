# =========================================================
# Dasturxon Backend — environment variables example
# Copy to .env (local/dev) or .env.staging / .env.prod and fill in real values.
# Never commit the real .env files — this is a TEMPLATE only, all secrets
# below are placeholders.
# =========================================================
DEBUG=True
# --- Django core ---
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# --- Postgres ---
# DB_ENGINE=sqlite switches to zero-setup local sqlite (see config/settings.py);
# anything else (default) uses Postgres via the vars below.
DB_ENGINE=postgres
POSTGRES_DB=dasturxon_dev
POSTGRES_USER=dasturxon_user
POSTGRES_PASSWORD=devpassword
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis (Celery broker/result backend, Channels layer, cache) ---
# NOTE: docker-compose's redis service runs with --requirepass, so every
# Redis URL below MUST include the password and use the `redis` service
# name as host (not localhost) when running under docker-compose.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=devpassword
REDIS_URL=redis://:devpassword@redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://:devpassword@redis:6379/1
CELERY_RESULT_BACKEND=redis://:devpassword@redis:6379/2
CELERY_CONCURRENCY=4
CELERY_TASK_ALWAYS_EAGER=False
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=True
CELERY_BROKER_CONNECTION_MAX_RETRIES=3

# --- JWT / Auth (Section 23) ---
JWT_ACCESS_TOKEN_LIFETIME_MIN=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30
OTP_RATE_LIMIT_PER_HOUR=5

# --- Object storage (Section 8) ---
# local (default): files saved to MEDIA_ROOT, served by nginx from the
#   media_volume Docker volume — free, zero setup, fine for a single VM.
# s3: any S3-compatible provider. For Cloudflare R2's free tier (10GB, no
#   egress fees), set AWS_S3_ENDPOINT_URL to
#   https://<account_id>.r2.cloudflarestorage.com and get the access keys
#   from the R2 dashboard -> "Manage R2 API Tokens".
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=dasturxon-media
AWS_S3_REGION_NAME=auto
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=

# --- Maps (Section 6) ---
GEOCODING_PROVIDER=yandex
YANDEX_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=
TWOGIS_API_KEY=

# --- Payments: Click (Section 19.6) ---
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_MERCHANT_USER_ID=
CLICK_SECRET_KEY=

# --- Payments: Payme (Section 19.7) ---
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# --- Notifications (Section 20) ---
SMS_PROVIDER=eskiz
SMS_API_KEY=
PUSH_PROVIDER=fcm
FCM_SERVER_KEY=
TELEGRAM_ADMIN_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Monitoring (Section 8, phase 2) ---
SENTRY_DSN=

# --- Nginx ---
NGINX_SERVER_NAME=localhost
HTTP_PORT=80
HTTPS_PORT=443

# --- Gunicorn (prod) ---
GUNICORN_WORKERS=4
GUNICORN_THREADS=2

# --- Eskiz SMS/email ---
ESKIZ_EMAIL=
ESKIZ_PASSWORD=

# --- Telegram bot ---
# WARNING: rotate any token that has ever been committed to git or shared
# in plaintext — regenerate it via @BotFather (/revoke) before deploying.
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_BOT_TOKEN=REPLACE_WITH_YOUR_BOT_TOKEN
TELEGRAM_WEBHOOK_SECRET=random-string-change-me
BACKEND_BASE_URL=http://localhost:8000
TELEGRAM_BOT_SHARED_SECRET=random-string-change-me

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
