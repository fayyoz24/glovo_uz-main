# =========================================================
# Glovo UZ Backend — environment variables
# Copy to .env and fill in real values.
# Never commit .env to git!
# =========================================================

# --- Django core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Postgres ---
POSTGRES_DB=glovo_uz_dev
POSTGRES_USER=glovo_user
POSTGRES_PASSWORD=devpassword
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MIN=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# --- Storage (S3) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=glovo-uz-media
AWS_S3_REGION_NAME=eu-central-1

# --- FCM ---
FCM_SERVER_KEY=

# --- SMS ---
SMS_PROVIDER=eskiz
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
PLAYMOBILE_USERNAME=
PLAYMOBILE_PASSWORD=

# --- Telegram Bot (yagona auth usuli — SMS OTP endi ishlatilmaydi) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=GlovoUZBot
TELEGRAM_BOT_SHARED_SECRET=your-random-secret-string
TELEGRAM_ADMIN_CHAT_ID=
BACKEND_BASE_URL=http://localhost:8000

# --- Email ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@glovo.uz

# --- Payments ---
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_MERCHANT_USER_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# --- Maps ---
YANDEX_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=

# --- Monitoring ---
SENTRY_DSN=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173









